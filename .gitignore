# ===== Secrets / env =====
.env
.env.*
!.env.example
*.key
secrets/

# ===== Dataset =====
# The full 100k pool (487MB) and all raw bundle files stay out of git.
data/raw/
# Big/streamed data formats anywhere under data/ (the full pool is candidates.jsonl)
data/**/*.jsonl
data/**/*.jsonl.gz
data/**/*.xlsx
data/**/*.parquet
data/**/*.zip
# ...but DO commit the small public sample used for tests + the sandbox demo.
!data/sample/
!data/sample/**

# ===== Python =====
__pycache__/
*.py[cod]
.venv/
venv/
env/
.ipynb_checkpoints/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ===== Node (if any UI/tooling) =====
node_modules/
dist/
.vite/

# ===== Model / embedding caches & generated artifacts =====
.cache/
embeddings_cache/
*.faiss
*.index
models/downloaded/
# Pre-computed embedding artifacts (large, regenerable via precompute.py)
artifacts/*.npy
artifacts/*.npz
artifacts/*.memmap
*.memmap

# ===== OS / editor =====
.DS_Store
Thumbs.db
.idea/
.vscode/
*.log
