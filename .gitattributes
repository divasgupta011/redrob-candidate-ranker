# Normalize line endings: store everything as LF in the repo, check out native.
# Stops the "LF will be replaced by CRLF" warnings on Windows.
* text=auto eol=lf

# Explicit text types
*.py    text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.txt   text eol=lf
*.csv   text eol=lf
*.json  text eol=lf

# Binary assets — never normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.npy   binary
*.npz   binary
*.faiss binary
